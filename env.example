# Creamy environment example
# Copy to `.env` and fill in the values you need. Everything is optional unless noted.

# ---------------------------------------------------------------------------
# Agent runtime
# ---------------------------------------------------------------------------
# Model is given as `provider:model_id`. Code default: openrouter:qwen/qwen3-coder-next
# CREAMY_MODEL=openrouter:qwen/qwen3-coder-next
# CREAMY_MAX_STEPS=50
# CREAMY_MAX_TOKENS=1024
# CREAMY_MODEL_TIMEOUT_SECONDS=300
# CREAMY_HOME=~/.creamy

# ---------------------------------------------------------------------------
# Provider credentials
# ---------------------------------------------------------------------------
# Settings read CREAMY_API_KEY and CREAMY_API_BASE directly. Provider-specific
# keys such as OPENROUTER_API_KEY may still be picked up by the underlying SDK.
# CREAMY_API_KEY=sk-...
# CREAMY_API_BASE=https://openrouter.ai/api/v1

# Upstream request shape:
#   completion  - completion-style requests (default)
#   responses   - OpenAI Responses API
#   messages    - chat-completions-style messages API
# CREAMY_API_FORMAT=completion

# Optional JSON forwarded to the model client (set to `null` to disable).
# CREAMY_CLIENT_ARGS={"extra_headers":{"X-Title":"Creamy"}}

# ---------------------------------------------------------------------------
# Channel manager
# ---------------------------------------------------------------------------
# Comma-separated channel names, or `all` (which excludes the builtin `cli`).
# CREAMY_ENABLED_CHANNELS=all
# CREAMY_DEBOUNCE_SECONDS=1.0
# CREAMY_MAX_WAIT_SECONDS=10.0
# CREAMY_ACTIVE_TIME_WINDOW=60.0

# ---------------------------------------------------------------------------
# Telegram channel (optional)
# ---------------------------------------------------------------------------
# CREAMY_TELEGRAM_TOKEN=123456:telegram-bot-token
# CREAMY_TELEGRAM_ALLOW_USERS=123456789,my_username
# CREAMY_TELEGRAM_ALLOW_CHATS=123456789,-1001234567890
# CREAMY_TELEGRAM_PROXY=http://127.0.0.1:1080

# ---------------------------------------------------------------------------
# Feishu channel (optional)
# ---------------------------------------------------------------------------
# CREAMY_FEISHU_APP_ID=cli_...
# CREAMY_FEISHU_APP_SECRET=...
# CREAMY_FEISHU_ALLOW_USERS=
# CREAMY_FEISHU_ALLOW_CHATS=

# ---------------------------------------------------------------------------
# Embedding model (optional)
# ---------------------------------------------------------------------------
# CREAMY_Embedding_model_name=
# CREAMY_Embedding_api_key=

# ---------------------------------------------------------------------------
# Postgres / pgvector store (optional)
# ---------------------------------------------------------------------------
# CREAMY_SQL_host=localhost
# CREAMY_SQL_port=5432
# CREAMY_SQL_user=creamy
# CREAMY_SQL_password=
# CREAMY_SQL_dbname=creamy
